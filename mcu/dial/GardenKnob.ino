// ----------------------------- Geometry -------------------------------------




// Six polygons representing the e-ink garden geometry. Coordinates are normalized
// to a 100x100 local garden map and then scaled into the circular safe display area.
// Garden geometry copied from GardenEInkZoneDisplay.ino.
// E-ink source polygons:
// Z1={{24,80},{180,80},{190,150},{140,230},{32,220}}
// Z2={{192,82},{320,82},{330,180},{230,200}}
// Z3={{332,82},{420,82},{420,220},{332,220}}
// Z4={{36,232},{190,232},{180,410},{22,410}}
// Z5={{192,210},{420,210},{420,420},{192,420}}
//
// Rotary display still uses six polygons because Zone 4 is two linked pieces.
// POLY0 + POLY1 are a split of the e-ink Z4 footprint.
static const MapPt POLY0[] = { {22,410}, {22,318}, {104,318}, {104,410} };                         // Zone 4 lower-left piece
static const MapPt POLY1[] = { {104,232}, {190,232}, {180,410}, {104,410} };                       // Zone 4 middle/right piece
static const MapPt POLY2[] = { {24,80}, {180,80}, {190,150}, {140,230}, {32,220} };                // Zone 1 = e-ink Z1
static const MapPt POLY3[] = { {192,82}, {320,82}, {330,180}, {230,200} };                         // Zone 5 = e-ink Z2
static const MapPt POLY4[] = { {332,82}, {420,82}, {420,220}, {332,220} };                         // Zone 3 = e-ink Z3
static const MapPt POLY5[] = { {192,210}, {420,210}, {420,420}, {192,420} };                       // Zone 2 = e-ink Z5

Poly polys[6] = {
  { POLY0, 4, 0, 0 },
  { POLY1, 4, 0, 0 },
  { POLY2, 5, 0, 0 },
  { POLY3, 4, 0, 0 },
  { POLY4, 4, 0, 0 },
  { POLY5, 4, 0, 0 }
};

static const uint8_t zoneToPolys[5][2] = {
  {2, 255}, // Zone 1 = e-ink Z1
  {5, 255}, // Zone 2 = e-ink Z5
  {4, 255}, // Zone 3 = e-ink Z3
  {0, 1},   // Zone 4 = split e-ink Z4
  {3, 255}  // Zone 5 = e-ink Z2
};

float mapMinX = 22;
float mapMaxX = 420;
float mapMinY = 80;
float mapMaxY = 420;
float mapScale = 1.0f;
float mapOffX = 0.0f;
float mapOffY = 0.0f;

ScreenPt toScreen(const MapPt &p) {
  ScreenPt s;
  s.x = (int16_t)roundf(mapOffX + (p.x - mapMinX) * mapScale);
  s.y = (int16_t)roundf(mapOffY + (p.y - mapMinY) * mapScale);
  return s;
}

void computePolyCentroids() {
  for (int i = 0; i < 6; i++) {
    float sx = 0, sy = 0;
    for (int j = 0; j < polys[i].n; j++) {
      sx += polys[i].pts[j].x;
      sy += polys[i].pts[j].y;
    }
    polys[i].cx = sx / polys[i].n;
    polys[i].cy = sy / polys[i].n;
  }
}

void setupMapTransform() {
  float w = mapMaxX - mapMinX;
  float h = mapMaxY - mapMinY;
  float target = 196.0f;
  mapScale = min(target / w, target / h);
  float scaledW = w * mapScale;
  float scaledH = h * mapScale;
  mapOffX = CX - scaledW / 2.0f - mapMinX * mapScale;
  mapOffY = CY - scaledH / 2.0f - mapMinY * mapScale - 2.0f;
}

bool pointInPolyScreen(uint8_t polyIndex, int px, int py) {
  bool inside = false;
  const Poly &poly = polys[polyIndex];
  for (int i = 0, j = poly.n - 1; i < poly.n; j = i++) {
    ScreenPt pi = toScreen(poly.pts[i]);
    ScreenPt pj = toScreen(poly.pts[j]);
    bool intersect = ((pi.y > py) != (pj.y > py)) &&
      (px < (pj.x - pi.x) * (py - pi.y) / (float)((pj.y - pi.y) == 0 ? 1 : (pj.y - pi.y)) + pi.x);
    if (intersect) inside = !inside;
  }
  return inside;
}

int polygonToZoneNumber(uint8_t polyIndex) {
  for (int z = 0; z < 5; z++) {
    if (zoneToPolys[z][0] == polyIndex || zoneToPolys[z][1] == polyIndex) return z + 1;
  }
  return -1;
}

