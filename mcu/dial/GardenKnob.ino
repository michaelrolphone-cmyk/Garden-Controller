ScreenPt toZoneScreen(const MapPt &p, float minX, float maxX, float minY, float maxY) {
  float w = maxX - minX;
  float h = maxY - minY;
  if (w < 1) w = 1;
  if (h < 1) h = 1;

  // Fit selected-zone geometry inside the 140x86 card.
  // Keep generous padding so polygons do not overlap title/header text or escape the backdrop.
  float targetW = 88.0f;
  float targetH = 50.0f;
  float s = min(targetW / w, targetH / h);

  ScreenPt out;
  out.x = (int16_t)roundf(CX + (p.x - (minX + maxX) / 2.0f) * s);
  out.y = (int16_t)roundf(125 + (p.y - (minY + maxY) / 2.0f) * s);
  return out;
}

