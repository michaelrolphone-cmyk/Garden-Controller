void drawScheduleTimeline(int x, int y, int w, int h, ZoneSchedule &zs, uint16_t accent) {
  gfx->drawRoundRect(x, y, w, h, 8, dimColor(accent));
  gfx->drawLine(x + 8, y + h / 2, x + w - 8, y + h / 2, C_PANEL);
  if (!zs.loaded || zs.count == 0) return;
