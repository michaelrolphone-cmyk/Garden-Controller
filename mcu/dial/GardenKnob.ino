void drawRunningFull() {
  fillCircularBackground();
  // Clear only the running content area on same-screen full redraws.
  gfx->fillRoundRect(24, 22, 192, 190, 18, C_BG);
  drawConnectionDot();

  RunItem *r = nullptr;
  bool selectedSpigot = false;
  int count = activeRunningItemCount();

  if (count > 0) {
    selectRunningItemByIndex(runningDisplayIndex, &r, &selectedSpigot);
  }

  if (r) {
    displayedRunningZone = r->zoneNumber;
    displayedRunningSpigot = false;
    long rem = localRemaining(*r);
    uint16_t accent = zoneUiColor(r->zoneNumber);
    float frac = (r->durationSeconds > 0) ? (float)rem / (float)r->durationSeconds : 0.0f;
    drawProgressRing(frac, accent);
    drawPlainTitle("Zone " + String(r->zoneNumber), "Running", accent);
    drawCenteredText(fmtDuration(rem), 94, 4, C_TEXT);
    drawCenteredText("remaining", 136, 2, C_SOFT_TEXT);
  } else if (selectedSpigot || spigotRun.active) {
    displayedRunningZone = 0;
    displayedRunningSpigot = true;
    long rem = localRemaining(spigotRun);
    float frac = (spigotRun.durationSeconds > 0) ? (float)rem / (float)spigotRun.durationSeconds : 0.0f;
    drawProgressRing(frac, C_CYAN);
    drawPlainTitle("Spigots", "Running", C_CYAN);
    drawCenteredText(fmtDuration(rem), 94, 4, C_TEXT);
    drawCenteredText("remaining", 136, 2, C_SOFT_TEXT);
  } else {
    displayedRunningZone = 0;
    displayedRunningSpigot = false;
    drawPlainTitle("Water Off", "Status", C_GREEN);
    drawCenteredText("No active run", 108, 2, C_TEXT);
  }

  String stopLabel = displayedRunningSpigot ? "Stop Spigot" : (displayedRunningZone > 0 ? "Stop Zone" : "Back");
  drawRoundButton(54, SAFE_BOTTOM_BUTTON_Y, 132, 28, stopLabel, C_RED, C_RED);

  actuallyDrawnScreen = SCR_RUNNING;
  lastRenderedRunningZone = displayedRunningZone;
  lastRenderedRunningSpigot = displayedRunningSpigot;

  if (displayedRunningZone > 0) {
    RunItem &rr = zoneRuns[displayedRunningZone - 1];
    lastRenderedRunningText = fmtDuration(localRemaining(rr));
    lastRenderedRunningFrac = (rr.durationSeconds > 0) ? (float)localRemaining(rr) / (float)rr.durationSeconds : 0.0f;
  } else if (displayedRunningSpigot) {
    lastRenderedRunningText = fmtDuration(localRemaining(spigotRun));
    lastRenderedRunningFrac = (spigotRun.durationSeconds > 0) ? (float)localRemaining(spigotRun) / (float)spigotRun.durationSeconds : 0.0f;
  } else {
    lastRenderedRunningText = "";
    lastRenderedRunningFrac = -1.0f;
  }
}

int activeRunningItemCount() {
  int count = activeZoneCount();
  if (spigotRun.active) count++;
  return count;
}

bool selectRunningItemByIndex(int idx, RunItem **zoneRun, bool *isSpigot) {
  int total = activeRunningItemCount();
  if (total <= 0) {
    *zoneRun = nullptr;
    *isSpigot = false;
    return false;
  }

  while (idx < 0) idx += total;
  while (idx >= total) idx -= total;
  runningDisplayIndex = idx;

  int seen = 0;
  for (int i = 0; i < 5; i++) {
    if (zoneRuns[i].active) {
      if (seen == idx) {
        *zoneRun = &zoneRuns[i];
        *isSpigot = false;
        return true;
      }
      seen++;
    }
  }

  if (spigotRun.active && seen == idx) {
    *zoneRun = nullptr;
    *isSpigot = true;
    return true;
  }

  *zoneRun = nullptr;
  *isSpigot = false;
  return false;
}

void updateRunningCountdownOnly() {
  RunItem *r = nullptr;
  bool selectedSpigot = false;
  int count = activeRunningItemCount();

  if (count > 0) {
    selectRunningItemByIndex(runningDisplayIndex, &r, &selectedSpigot);
  }

  int currentZone = 0;
  bool currentSpigot = false;
  long rem = 0;
  long dur = 0;
  uint16_t accent = C_GREEN;

  if (r) {
    currentZone = r->zoneNumber;
    currentSpigot = false;
    rem = localRemaining(*r);
    dur = r->durationSeconds;
    accent = zoneUiColor(r->zoneNumber);
  } else if (selectedSpigot || spigotRun.active) {
    currentZone = 0;
    currentSpigot = true;
    rem = localRemaining(spigotRun);
    dur = spigotRun.durationSeconds;
    accent = C_CYAN;
  } else {
    drawRunningFull();
    return;
  }

  float frac = (dur > 0) ? (float)rem / (float)dur : 0.0f;
  if (frac < 0.0f) frac = 0.0f;
  if (frac > 1.0f) frac = 1.0f;
  String remText = fmtDuration(rem);

  bool structureChanged =
    actuallyDrawnScreen != SCR_RUNNING ||
    currentZone != lastRenderedRunningZone ||
    currentSpigot != lastRenderedRunningSpigot;

  if (structureChanged) {
    drawRunningFull();
    return;
  }

  if (remText != lastRenderedRunningText || ((frac > lastRenderedRunningFrac ? frac - lastRenderedRunningFrac : lastRenderedRunningFrac - frac) > 0.01f)) {
    drawProgressRing(frac, accent);

    gfx->fillRoundRect(44, 84, 152, 58, 14, C_BG);
    drawCenteredText(remText, 94, 4, C_TEXT);
    drawCenteredText("remaining", 136, 2, C_SOFT_TEXT);

    lastRenderedRunningText = remText;
    lastRenderedRunningFrac = frac;
    lastRunningPartialDrawMs = millis();
    presentDisplay();
  }
}

void drawRunning() {
  drawRunningFull();
}



