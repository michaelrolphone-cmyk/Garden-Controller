// Arduino IDE generates function prototypes near the top of .ino files.
// These shared types must be declared before that prototype pass sees functions
// such as toScreen(), localRemaining(), readTouch(), and go().




// ----------------------------- Async Relay I/O -------------------------------
// ESP32-S3 has two cores. Keep touch/encoder/UI responsive on the Arduino loop
// while relay HTTP runs in a FreeRTOS task pinned to core 0.
enum AsyncRelayCommandType {
  RCMD_NONE = 0,
  RCMD_MANUAL_RUN,
  RCMD_SPIGOT_RUN,
  RCMD_STOP_ZONE,
  RCMD_STOP_SPIGOTS,
  RCMD_ALL_OFF,
  RCMD_SEND_SCHEDULE,
  RCMD_DELETE_SCHEDULE,
  RCMD_RELOAD_STATE,
  RCMD_RELOAD_SCHEDULE
};

struct AsyncRelayCommand {
  AsyncRelayCommandType type = RCMD_NONE;
  int zone = 0;
  int minutes = 0;
  int hour = 0;
  int minute = 0;
  int duration = 0;
  int slot = 0;
  bool enabled = true;
};

static QueueHandle_t relayCommandQueue = nullptr;
static TaskHandle_t relayWorkerHandle = nullptr;
static volatile bool relayWorkerReady = false;
static volatile bool relayIoBusy = false;
static uint32_t lastAsyncStatePollMs = 0;
static uint32_t lastAsyncSchedulePollMs = 0;

static const uint32_t RELAY_STALE_MS = 15000;
static const uint8_t RELAY_FAILS_TO_DISCONNECT = 3;
static volatile uint32_t lastRelaySuccessMs = 0;
static volatile uint8_t relayConsecutiveFailures = 0;


