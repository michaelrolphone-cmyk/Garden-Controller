bool zoneContainsPoly(int zoneNumber, uint8_t polyIndex) {
  if (zoneNumber < 1 || zoneNumber > 5) return false;
  return zoneToPolys[zoneNumber - 1][0] == polyIndex || zoneToPolys[zoneNumber - 1][1] == polyIndex;
}

